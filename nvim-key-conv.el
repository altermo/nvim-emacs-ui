        (kp-9 . "k9")))

(setq nvim-key-conv-mod-map
      '((shift . ?S)
        (control . ?C)
        (meta . ?M)
        (alt . ?A)
        ; (meta . ?T)
        ; (hyper . ?)
        (super . ?D)))

(defun nvim-key-conv (keys)
  (mapconcat
    (lambda (key)
      (catch
        'nvim-key-conv
        (cond
          ((or (event-modifiers key) (assq (event-basic-type key) nvim-key-conv-map))
           (concat "<"
                   (mapconcat (lambda (mod)
                                (string (or
                                          (alist-get mod nvim-key-conv-mod-map)
                                          (throw 'nvim-key-conv "")
                                          ) ?-))
                              (event-modifiers key))
                   (or
                     (alist-get (event-basic-type key) nvim-key-conv-map)
                     (string (event-basic-type key)))
                   ">")
           )
          ((eq (type-of key) 'integer) (string key))
          (t (throw 'nvim-key-conv "")))))
    keys))

(provide 'nvim-key-conv)
