        (kp-prior . "kPageUp")
        (kp-next . "kPageDown")
        (kp-delete . "kDel")
        (kp-add . "kPlus")
        (kp-subtract . "kMinus")
        (kp-multiply . "kMultiply")
        (kp-divide . "kDivide")
        (kp-decimal . "kPoint")
