(require 'seq)

(setq nvim-key-conv-map
      '((backspace . "BS")
        (?\t . "Tab")
        (tab . "Tab")
        (linefeed . "NL")
        (?\r . "CR")
        (return . "CR")
        (escape . "Esc")
        (?\e . "Esc")
        (space . "Space")
        (32 . "Space")
        (?< . "lt")
        (delete . "Del")
        (127 . "Del")
        (up . "Up")
        (down . "Down")
        (left . "Left")
        (right . "Right")
        (f1 .  "f1")
        (f2 .  "f2")
        (f3 .  "f3")
        (f4 .  "f4")
        (f5 .  "f5")
        (f6 .  "f6")
        (f7 .  "f7")
        (f8 .  "f8")
        (f9 .  "f9")
        (f10 . "f10")
        (f11 . "f11")
        (f12 . "f12")
        (f13 . "f13")
        (f14 . "f14")
        (f15 . "f15")
        (f16 . "f16")
        (f17 . "f17")
        (f18 . "f18")
        (f19 . "f19")
        (f20 . "f20")
        (f21 . "f21")
        (f22 . "f22")
        (f23 . "f23")
        (f24 . "f24")
        (help . "Help")
        (undo . "Undo")
        (find . "Find")
        (select . "Select")
        (insert . "Insert")
